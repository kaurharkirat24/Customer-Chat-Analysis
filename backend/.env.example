# AI Model Keys (LangGraph Agent)
GEMINI_API_KEY="your-gemini-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here-optional"

# Authentication Secrets
SECRET_KEY="replace-this-with-a-random-secure-string"
GOOGLE_CLIENT_ID="your-google-web-client-id.apps.googleusercontent.com"

# RAG/Vector DB 
PINECONE_API_KEY="your-pinecone-api-key-here"

# AWS S3 Attachment Storage
AWS_ACCESS_KEY_ID="your_access_key_here"
AWS_SECRET_ACCESS_KEY="your_secret_key_here"
AWS_DEFAULT_REGION="your_aws_region_here"
AWS_S3_BUCKET_NAME="your_exact_bucket_name"

# Database Configuration
# For SQLite (default if not set): sqlite:///./cxflow.db
# For PostgreSQL (Docker): postgresql://cxflow_user:cxflow_password@localhost:5432/cxflow_db
DATABASE_URL="postgresql://cxflow_user:cxflow_password@localhost:5432/cxflow_db"
